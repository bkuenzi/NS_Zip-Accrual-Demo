# ── Runtime mode ─────────────────────────────────────────────────────────────
# mock  = all integrations served by seeded mock adapters (no credentials needed)
# live  = real NetSuite / Zip / ad-platform / email connections
ACCRUAL_MODE=mock

# dry_run = render + log outbound email, send nothing (default; forced in mock mode)
# sandbox = send only to SANDBOX-allowlisted domains / redirect address
# live    = real sends (explicit opt-in)
ACCRUAL_OUTBOUND_MODE=dry_run
ACCRUAL_SANDBOX_ALLOWED_DOMAINS=example-sandbox.com
ACCRUAL_SANDBOX_REDIRECT=            # optional: redirect ALL sandbox mail to this address

# ── Close & policy configuration ─────────────────────────────────────────────
ACCRUAL_BASE_CURRENCY=USD
ACCRUAL_CLOSE_TIMEZONE=America/New_York
ACCRUAL_VARIANCE_THRESHOLD_PCT=5.0          # global ±% invoice/confirmation variance gate
ACCRUAL_MATERIALITY_FLOOR=250.00            # base-currency floor below which gaps are logged only
ACCRUAL_REMINDER_DAYS=[3,7,10]              # close-cycle days for escalating reminders
ACCRUAL_CHECKPOINT_DAYS=[5,10]              # exception-report checkpoints (final day always included)
ACCRUAL_AD_SETTLE_HOURS=72                  # ad-platform restatement window
ACCRUAL_REVERSAL_LOOKBACK_PERIODS=2         # prior periods scanned for invoice matches
ACCRUAL_ESCALATION_RERAISE_BUSINESS_DAYS=2  # staleness interval before an escalation re-raises

# ── Escalation delivery: comma-separated subset of {email,slack} ─────────────
ACCRUAL_ESCALATION_CHANNELS=email
ACCRUAL_TEAM_LEAD_EMAIL=accounting-lead@yourco.example
SLACK_WEBHOOK_URL=

# ── NetSuite (SuiteTalk REST, Token-Based Auth / OAuth 1.0a) ─────────────────
NETSUITE_ACCOUNT_ID=1234567
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=

# ── Zip (read-only) ──────────────────────────────────────────────────────────
ZIP_API_BASE_URL=https://api.ziphq.com
ZIP_API_KEY=

# ── Google Ads ───────────────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_OAUTH_CLIENT_ID=
GOOGLE_ADS_OAUTH_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_IDS=1234567890          # comma-separated ad account ids

# ── Meta Ads ─────────────────────────────────────────────────────────────────
META_ACCESS_TOKEN=
META_AD_ACCOUNT_IDS=act_123456789           # comma-separated ad account ids

# ── Email (dedicated accruals mailbox: From + Reply-To) ──────────────────────
ACCRUAL_MAILBOX_ADDRESS=accruals@yourco.example
SMTP_HOST=smtp.yourco.example
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
IMAP_HOST=imap.yourco.example
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=

# ── LLM reply-extraction fallback (optional) ─────────────────────────────────
ANTHROPIC_API_KEY=
ACCRUAL_LLM_MODEL=claude-haiku-4-5

# ── Storage ──────────────────────────────────────────────────────────────────
ACCRUAL_DB_PATH=data/accruals.db
ACCRUAL_OUTPUT_DIR=output
ACCRUAL_ARTIFACTS_DIR=output/artifacts
